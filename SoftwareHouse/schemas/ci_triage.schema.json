{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status",
    "failed_jobs",
    "suspected_causes",
    "recommended_fixes",
    "requires_new_ticket"
  ],
  "properties": {
    "status": {
      "type": "string"
    },
    "failed_jobs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "suspected_causes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_fixes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_new_ticket": {
      "type": "boolean"
    }
  }
}
