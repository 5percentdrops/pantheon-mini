{
  "type": "object",
  "required": [
    "ticket_id",
    "lane",
    "senior_owner",
    "standard_owner",
    "tasks",
    "pr_green_criteria"
  ],
  "properties": {
    "ticket_id": {
      "type": "string"
    },
    "lane": {
      "type": "string"
    },
    "senior_owner": {
      "type": "string"
    },
    "standard_owner": {
      "type": "string"
    },
    "touches": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "V8.13: Files/paths this ticket modifies (union of all task-level files_to_touch). Arthur uses this for collision detection before parallel-Jack fan-out. Two tickets with overlapping touches MUST execute sequentially; tickets with disjoint touches MAY parallelize. Marcus populates after writing the ticket; empty/missing means Arthur falls through to sequential mode (safe default)."
    },
    "isolation_hint": {
      "type": "string",
      "enum": ["isolated", "shared_module", "shared_repo_only", "global"],
      "description": "V8.13: Marcus's coarse assessment of how isolated this ticket is. 'isolated' = touches disjoint subtree, safe to parallelize. 'global' = touches root/config, MUST be sequential. Used as a secondary check alongside `touches` for fan-out eligibility."
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "objective",
          "red_test",
          "green_target",
          "task_green_criteria"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "objective": {
            "type": "string"
          },
          "files_to_touch": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "red_test": {
            "type": "string"
          },
          "green_target": {
            "type": "string"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "task_green_criteria": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "can_move_to_next_task": {
            "type": "boolean"
          }
        }
      }
    },
    "pr_green_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "merge_allowed": {
      "type": "boolean"
    }
  }
}