{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "ticket_id",
    "summary",
    "files_changed",
    "tests_run",
    "risks",
    "next_steps"
  ],
  "properties": {
    "ticket_id": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tests_run": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
