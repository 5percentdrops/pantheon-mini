{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "agent_id",
    "harness",
    "underlying_model",
    "allowed_tools",
    "forbidden_tools"
  ],
  "properties": {
    "agent_id": {
      "type": "string"
    },
    "harness": {
      "type": "string"
    },
    "underlying_model": {
      "type": "string"
    },
    "allowed_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbidden_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
