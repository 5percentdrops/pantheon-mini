{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sdd_qa_signoff.schema.json",
  "title": "SDD QA Signoff (V8.6)",
  "description": "Nadia's machine-readable signoff (or rejection) on a Marcus-emitted SDD, evaluated against PRD intent before TDD red tests are locked.",
  "type": "object",
  "required": ["ticket_id", "sdd_ref", "prd_ref", "decision", "reviewer", "timestamp_utc", "iteration"],
  "properties": {
    "ticket_id":     { "type": "string", "pattern": "^TKT-[A-Z0-9-]+$" },
    "sdd_ref":       { "type": "string", "description": "Path or URI of the SDD artifact under review" },
    "prd_ref":       { "type": "string", "description": "Path or URI of the source PRD" },
    "reviewer":      { "const": "senior-qa" },
    "iteration":     { "type": "integer", "minimum": 1, "maximum": 2 },
    "decision":      { "enum": ["approve", "return_to_marcus", "escalate_to_arthur"] },
    "prd_clauses_checked": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "List of PRD clause IDs/headings Nadia verified the SDD addresses"
    },
    "drift_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["prd_clause", "sdd_gap", "severity"],
        "properties": {
          "prd_clause": { "type": "string" },
          "sdd_gap":    { "type": "string" },
          "severity":   { "enum": ["blocker", "major", "minor"] }
        }
      }
    },
    "blocker_count":  { "type": "integer", "minimum": 0 },
    "must_fix_before_tdd": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timestamp_utc": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "decision": { "const": "approve" } } },
      "then": { "properties": { "blocker_count": { "const": 0 } } }
    },
    {
      "if": { "properties": { "decision": { "const": "return_to_marcus" } } },
      "then": { "required": ["drift_findings", "must_fix_before_tdd"] }
    },
    {
      "if": { "properties": { "decision": { "const": "escalate_to_arthur" } } },
      "then": { "properties": { "iteration": { "const": 2 } } }
    }
  ]
}
