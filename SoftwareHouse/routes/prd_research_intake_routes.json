{
  "routes": [
    {
      "name": "raw_idea_to_research_pack",
      "trigger": "user submits raw idea",
      "path": [
        "arthur-project-manager",
        "marcus-senior-backend-developer"
      ],
      "hard_rule": "Owen builds research base only.",
      "harness": "Hermes"
    },
    {
      "name": "research_to_bottleneck",
      "trigger": "Owen completes Research Pack",
      "path": [
        "marcus-senior-backend-developer",
        "marcus-senior-backend-developer"
      ],
      "hard_rule": "Vera maps APIs/data/source bottlenecks before feasibility.",
      "harness": "Hermes"
    },
    {
      "name": "bottleneck_to_feasibility",
      "trigger": "Vera completes API & Bottleneck Report",
      "path": [
        "marcus-senior-backend-developer",
        "magnus-principal-solution-architect"
      ],
      "hard_rule": "Graham must use Vera's bottleneck findings.",
      "harness": "Hermes"
    },
    {
      "name": "feasibility_to_skeptical_validation",
      "trigger": "Graham completes Feasibility Report",
      "path": [
        "magnus-principal-solution-architect",
        "cody-code-escalation-reviewer"
      ],
      "hard_rule": "Stone attacks Graham's assumptions.",
      "harness": "Hermes"
    },
    {
      "name": "skeptical_revision_loop",
      "trigger": "Stone finds serious holes",
      "path": [
        "cody-code-escalation-reviewer",
        "magnus-principal-solution-architect",
        "cody-code-escalation-reviewer"
      ],
      "hard_rule": "Graham must revise and Stone may re-check.",
      "harness": "Hermes"
    },
    {
      "name": "validated_feasibility_to_opportunity",
      "trigger": "Stone passes or Graham revises adequately",
      "path": [
        "cody-code-escalation-reviewer",
        "magnus-principal-solution-architect"
      ],
      "hard_rule": "Adrian only finds upside inside validated feasibility.",
      "harness": "Hermes"
    },
    {
      "name": "prd_package_to_user_approval",
      "trigger": "Adrian completes Opportunity Report",
      "path": [
        "magnus-principal-solution-architect",
        "arthur-project-manager",
        "user"
      ],
      "hard_rule": "Arthur delivers package to user.",
      "harness": "Hermes"
    },
    {
      "name": "approved_prd_to_domain_senior",
      "trigger": "user approves PRD",
      "path": [
        "arthur-project-manager",
        "relevant-senior-engineer"
      ],
      "hard_rule": "Arthur routes by technical domain, not automatically to Marcus.",
      "harness": "Hermes"
    }
  ]
}