{
  "version": "7.0",
  "harness": "Hermes",
  "rtk_role": "terminal_output_compression_only",
  "arthur": {
    "model": "GPT-5 mini under Hermes",
    "mode": "single_model",
    "role": "manager_router_state_controller",
    "low_confidence_action": "route_to_assigned_senior_or_user",
    "must_not": [
      "merge_to_main_silently",
      "bypass_senior_final_review",
      "route_without_namespace",
      "read_full_logs_by_default"
    ]
  },
  "attempts": {
    "1-12": "Jack / Junior Dev",
    "13-15": "Assigned Senior Specialist",
    "16-17": "Maxwell",
    "18": "Cody forensic audit",
    "19": "Magnus architecture rethink"
  },
  "success_path": [
    "Cody Pass",
    "Arthur route to Senior",
    "Senior final review",
    "Senior commit",
    "Senior PR draft",
    "MASTER_STATUS update",
    "Winston archive",
    "merge gate"
  ],
  "failure_path": [
    "Junior fail at 12",
    "Context Shredder",
    "Senior tactical fixes",
    "Maxwell deep fixes",
    "Cody forensic report",
    "Magnus structural pathways",
    "manual review"
  ],
  "caveman": {
    "default_mode": "FULL",
    "applies_to_all_agents": true,
    "only_exception": "Arthur raw escalation error extract",
    "exception_label": "CAVEMAN_MODE: EXCEPTION"
  },
  "arthur_escalation_handoff": {
    "route": "Arthur \u2192 Assigned Senior Developer",
    "failure_summary_max_lines": 50,
    "rtk_head_lines": 150,
    "rtk_tail_lines": 150,
    "send_to_senior_if_error_missing": true
  }
}